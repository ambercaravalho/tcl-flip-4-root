# Python virtualenv (recreate with: scripts/setup.sh)
.venv/

# Device backups / dumped images (huge, and contain personal data)
backups/*
!backups/.gitkeep
*.img
*.bin.dump

# Run logs
logs/*
!logs/.gitkeep
*.log

# edl runtime cache (auto-generated; contains device serial)
edl_config.json

# Rooting work: carved/patched images + unpack trees (generated, can be huge)
build/

# Fetched build tools (avbtool, mkbootimg, test keys) - see docs/ROOT.md to refetch
tools/*
# ...but keep our own source tool (built with libsepol; see docs/ROOT.md)
!tools/setpermissive.c

# Python caches
__pycache__/
*.py[cod]

# OS cruft
.DS_Store
